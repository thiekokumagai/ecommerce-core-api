generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  password     String
  role         Role     @default(USER)
  refreshToken String?
  createdAt    DateTime @default(now())

  @@map("users")
}

model Category {
  id        String    @id @default(uuid())
  title     String
  image     String?
  isVisible Boolean   @default(true)
  order     Int       @default(0)
  deletedAt DateTime?

  products Product[]

  @@map("categories")
}

model Variation {
  id        String    @id @default(uuid())
  title     String
  deletedAt DateTime?

  options  VariationOption[]
  products ProductVariation[]

  @@map("variations")
}

model VariationOption {
  id          String @id @default(uuid())
  value       String
  variationId String

  variation   Variation           @relation(fields: [variationId], references: [id])
  itemOptions ProductItemOption[]

  @@unique([variationId, value])
  @@map("variation_options")
}

model Product {
  id         String @id @default(uuid())
  title      String
  categoryId String

  category Category @relation(fields: [categoryId], references: [id])

  images     ProductImage[]
  variations ProductVariation[]
  items      ProductItem[]

  deletedAt DateTime?
  createdAt DateTime  @default(now())

  @@map("products")
}

model ProductImage {
  id        String @id @default(uuid())
  url       String
  productId String

  product Product @relation(fields: [productId], references: [id])

  @@map("product_images")
}

model ProductVariation {
  id          String @id @default(uuid())
  productId   String
  variationId String

  product   Product   @relation(fields: [productId], references: [id])
  variation Variation @relation(fields: [variationId], references: [id])

  @@unique([productId, variationId])
  @@map("product_variations")
}

model ProductItem {
  id        String @id @default(uuid())
  productId String
  stock     Int    @default(0)

  hash String @unique

  product Product             @relation(fields: [productId], references: [id])
  options ProductItemOption[]

  @@index([productId])
  @@map("product_items")
}

model ProductItemOption {
  id       String @id @default(uuid())
  itemId   String
  optionId String

  item   ProductItem     @relation(fields: [itemId], references: [id])
  option VariationOption @relation(fields: [optionId], references: [id])

  @@unique([itemId, optionId])
  @@map("product_item_options")
}
